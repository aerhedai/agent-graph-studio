{
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git checkout*)",
      "Bash(git branch*)",
      "Bash(git pull)",
      "Bash(git push*)",
      "Bash(gh issue*)",
      "Bash(gh pr*)",
      "Bash(gh project*)",
      "Bash(uv run pytest*)",
      "Bash(uv sync*)",
      "Bash(uv run agent-graph-studio*)",
      "Read",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)"
    ],
    "defaultMode": "default"
  }
}