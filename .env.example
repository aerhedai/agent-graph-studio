# Agent Graph Studio -- local environment configuration.
#
# Copy this file to `.env` (already git-ignored) and fill in real values.
# `.env` is loaded automatically by `uv run uvicorn backend.api.app:app --reload`
# and by `uv run agent-graph-studio <graph.json>` (see backend/api/app.py and
# backend/cli/main.py) via python-dotenv -- no `export` needed for local dev.
# Docker Compose does NOT read this file; it reads real environment variables
# / its own `.env` next to docker-compose.yml (see docs/DEPLOYMENT.md).
#
# Every var below is read via `os.environ` somewhere in backend/ -- nothing
# here is unused.

# --- Required -- the backend refuses to start without these (fail-closed) --

# Fernet key encrypting connection secrets (bot tokens, API keys) at rest
# (SPEC-017). Generate: uv run python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AGENT_GRAPH_STUDIO_ENCRYPTION_KEY=

# The shared credential machine callers use -- webhook URLs external
# services hit directly, via ?key= (SPEC-017, narrowed to machine-to-machine
# use by SPEC-020). Any string you choose.
AGENT_GRAPH_STUDIO_API_KEY=

# Signs session tokens issued after Google sign-in (SPEC-020). A long random
# string (>=32 bytes), distinct from the encryption key above -- signing
# sessions and encrypting connection secrets are different security domains.
# Generate: uv run python3 -c "import secrets; print(secrets.token_urlsafe(32))"
AGENT_GRAPH_STUDIO_JWT_SECRET=

# Google OAuth 2.0 Web application client, from
# https://console.cloud.google.com/apis/credentials -- add
# {your public base URL}/auth/google/callback as an authorized redirect URI
# on that client (the same URL set via Settings -> Public base URL in the
# app once it's running).
AGENT_GRAPH_STUDIO_GOOGLE_CLIENT_ID=
AGENT_GRAPH_STUDIO_GOOGLE_CLIENT_SECRET=

# The Google account email bootstrapped as the first admin (invite-
# allowlisted with role=admin) on every startup (SPEC-020). Must be a real
# Gmail/Google Workspace address you can actually sign into.
AGENT_GRAPH_STUDIO_ADMIN_EMAIL=

# --- Optional -- storage locations, sensible defaults under ~/.agent-graph-studio/ ---
# Uncomment and set only if you want data to live somewhere other than the
# default (e.g. to point multiple checkouts at the same data, or to isolate
# a throwaway test run without touching your real data).

# AGENT_GRAPH_STUDIO_CONNECTIONS_PATH=
# AGENT_GRAPH_STUDIO_RUNS_DB_PATH=
# AGENT_GRAPH_STUDIO_GRAPHS_DB_PATH=
# AGENT_GRAPH_STUDIO_USERS_DB_PATH=
# AGENT_GRAPH_STUDIO_SETTINGS_PATH=
